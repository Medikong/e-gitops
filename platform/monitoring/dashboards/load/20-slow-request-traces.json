          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | event=\"http.request.completed\" | http_route_kind=\"api\" | http_route=~\"$route\" | http_status_code=~\"5..\" | line_format \"service={{.service_name}} method={{.http_method}} route={{.http_route}} status={{.http_status_code}} duration_ms={{.duration_ms}} request_id={{.request_id}} trace_id={{.trace_id}} span_id={{.span_id}}\"",
          "legendFormat": "",
