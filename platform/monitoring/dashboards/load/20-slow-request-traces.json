    {
      "id": 2,
      "title": "Slow Requests by Route",
      "type": "timeseries",
      "description": "Retained slow request logs by route.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name, http_route) (count_over_time({k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | event=\"http.request.completed\" | http_route_kind=\"api\" | http_route=~\"$route\" | duration_ms >= $min_duration_ms [$__interval]))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
