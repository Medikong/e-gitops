    {
      "id": 5,
      "title": "Tempo Traces over Threshold",
      "type": "table",
      "description": "Tempo traces remain searchable even when sampled access logs are absent.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "editorMode": "builder",
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" && duration > $tempo_min_duration }",
          "limit": 100,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      }
    },
