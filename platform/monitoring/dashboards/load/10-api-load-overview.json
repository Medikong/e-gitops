  "panels": [
    {
      "id": 1,
      "title": "Scope",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "**Representative screen 4/4.** Use this while generating traffic against a selected DropMong API route. It relies on the common application HTTP metrics and Kubernetes resources. No k6 result series or ingress-controller metric is shown because those collection contracts are not active."
      }
    },
    {
      "id": 2,
      "title": "Request Rate by Route",
      "type": "timeseries",
      "description": "Completed requests per second for active DropMong route templates.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name, http_route) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} {{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Open slow request traces",
          "url": "/d/dropmong-load-slow-request-traces/load-20-slow-request-traces?orgId=1&var-environment=$environment&var-namespace=$namespace&var-service=$service&var-route=$route&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "p95 / p99 Latency by Route",
      "type": "timeseries",
      "description": "Application-observed route latency.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (service_name, http_route, le) (rate(http_server_request_duration_seconds_bucket{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval])))",
          "legendFormat": "p95 {{service_name}} {{http_route}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (service_name, http_route, le) (rate(http_server_request_duration_seconds_bucket{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval])))",
          "legendFormat": "p99 {{service_name}} {{http_route}}",
          "range": true,
          "refId": "B"
        }
      ],
      "links": [
        {
          "title": "Open slow request traces",
          "url": "/d/dropmong-load-slow-request-traces/load-20-slow-request-traces?orgId=1&var-environment=$environment&var-namespace=$namespace&var-service=$service&var-route=$route&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "5xx Ratio by Route",
      "type": "timeseries",
      "description": "5xx share under load. Empty data is not interpreted as success.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (service_name, http_route) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\",http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service_name, http_route) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{service_name}} {{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Open slow request traces",
          "url": "/d/dropmong-load-slow-request-traces/load-20-slow-request-traces?orgId=1&var-environment=$environment&var-namespace=$namespace&var-service=$service&var-route=$route&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
