{
  "annotations": {
    "list": []
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Investigation Order",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "Use DB 10 to identify the owner namespace, search Tempo for slow or failed PostgreSQL spans, then paste `trace_id` to inspect retained service logs and the complete trace. There is no verified `db.query.slow` log contract, so this dashboard does not invent one."
      }
    },
    {
      "id": 2,
      "title": "Slow or Failed PostgreSQL Traces",
      "type": "table",
      "description": "SQL statement text is not required for this search; service, operation, duration and trace context are sufficient entry points.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "editorMode": "builder",
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" && span.db.system = \"postgresql\" && (status = error || duration > $min_duration) }",
          "limit": 50,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      }
    },
    {
      "id": 3,
      "title": "Selected Trace Logs",
      "type": "logs",
      "description": "Retained service logs for the selected trace.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | trace_id=~\"$trace_id\" | line_format \"event={{.event}} service={{.service_name}} route={{.http_route}} status={{.http_status_code}} request_id={{.request_id}} trace_id={{.trace_id}} span_id={{.span_id}}\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 4,
      "title": "Selected Request Logs",
      "type": "logs",
      "description": "Use request_id when a client report does not include trace_id.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | request_id=~\"$request_id\" | line_format \"event={{.event}} service={{.service_name}} route={{.http_route}} request_id={{.request_id}} trace_id={{.trace_id}} span_id={{.span_id}}\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 5,
      "title": "Selected Span Log",
      "type": "logs",
      "description": "span_id identifies the exact logged operation within a trace.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | trace_id=~\"$trace_id\" | span_id=~\"$span_id\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 6,
      "title": "Tempo Trace by trace_id",
      "type": "traces",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceId",
          "query": "$trace_id",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
