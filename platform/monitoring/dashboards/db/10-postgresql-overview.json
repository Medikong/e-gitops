  "panels": [
    {
      "id": 1,
      "title": "Scope",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      },
      "options": {
        "mode": "markdown",
        "content": "**Representative screen 3/4.** Active PostgreSQL data-plane owners are auth, user, catalog, coupon, interest, order and payment. `notification-service` requires PostgreSQL in application values, but no active DB manifest/exporter exists yet, so it is not presented as a monitored DB owner."
      }
    },
    {
      "id": 2,
      "title": "PostgreSQL Up",
      "type": "stat",
      "description": "Exporter-reported PostgreSQL availability. Missing data remains no data.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "min by (namespace, pod) (pg_up{namespace=~\"$namespace\"})",
          "legendFormat": "{{namespace}} / {{pod}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "title": "Connection Usage",
      "type": "timeseries",
      "description": "Open application connections divided by configured max connections.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 9,
        "h": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (namespace) (pg_stat_activity_count{namespace=~\"$namespace\",datname!~\"template.*|postgres\"}) / clamp_min(sum by (namespace) (pg_settings_max_connections{namespace=~\"$namespace\"}), 1)",
          "legendFormat": "{{namespace}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Open DB trace correlation",
          "url": "/d/dropmong-db-trace-correlation/db-20-db-trace-correlation?orgId=1&var-namespace=$namespace&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "Transactions per Second",
      "type": "timeseries",
      "description": "Committed and rolled-back transactions.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 15,
        "y": 4,
        "w": 9,
        "h": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace) (rate(pg_stat_database_xact_commit{namespace=~\"$namespace\",datname!~\"template.*|postgres\"}[$__rate_interval]))",
          "legendFormat": "commit / {{namespace}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace) (rate(pg_stat_database_xact_rollback{namespace=~\"$namespace\",datname!~\"template.*|postgres\"}[$__rate_interval]))",
          "legendFormat": "rollback / {{namespace}}",
          "range": true,
          "refId": "B"
        }
      ],
      "links": [
        {
          "title": "Open DB trace correlation",
          "url": "/d/dropmong-db-trace-correlation/db-20-db-trace-correlation?orgId=1&var-namespace=$namespace&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "title": "Rollback Ratio",
      "type": "timeseries",
      "description": "Rollback share of completed transactions.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (namespace) (rate(pg_stat_database_xact_rollback{namespace=~\"$namespace\",datname!~\"template.*|postgres\"}[$__rate_interval])) / clamp_min(sum by (namespace) (rate(pg_stat_database_xact_commit{namespace=~\"$namespace\",datname!~\"template.*|postgres\"}[$__rate_interval]) + rate(pg_stat_database_xact_rollback{namespace=~\"$namespace\",datname!~\"template.*|postgres\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{namespace}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Open DB trace correlation",
          "url": "/d/dropmong-db-trace-correlation/db-20-db-trace-correlation?orgId=1&var-namespace=$namespace&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
