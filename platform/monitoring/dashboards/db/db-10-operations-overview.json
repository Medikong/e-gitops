    {
      "title": "Connection Usage",
      "type": "timeseries",
      "description": null,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (namespace) (pg_stat_activity_count{namespace=~\"${namespace:regex}\",datname!~\"template.*|postgres\"}) / clamp_min(sum by (namespace) (pg_settings_max_connections{namespace=~\"${namespace:regex}\"}), 1)",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
