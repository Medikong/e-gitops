        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "editorMode": "builder",
          "query": "{}",
          "queryType": "traceql",
          "limit": 100,
          "range": true,
          "refId": "A"
        }
      ]
    },
