    {
      "id": 9,
      "title": "Trace / Span Focus",
      "type": "logs",
      "description": "Use trace_id for the full trace; span_id narrows the log line to one operation.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 8,
