      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceId",
          "query": "$trace_id",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Recent Error or Slow Traces",
      "type": "table",
      "description": "Tempo search is independent of retained access-log sampling.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "editorMode": "builder",
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" && (status = error || duration > 1s) }",
          "limit": 50,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      }
    }
