    {
      "id": 10,
      "title": "Tempo Trace by trace_id",
      "type": "traces",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 16,
        "y": 17,
        "w": 8,
        "h": 8
