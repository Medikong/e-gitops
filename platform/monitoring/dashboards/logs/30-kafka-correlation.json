          },
          "editorMode": "code",
          "expr": "{service_name=~\"$service\"} | json | trace_id=~\"$trace_id\" | span_id=~\"$span_id\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
