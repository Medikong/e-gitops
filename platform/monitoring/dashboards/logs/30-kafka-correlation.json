    },
    {
      "id": 8,
      "title": "Tempo Trace by trace_id",
      "type": "traces",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceId",
          "query": "$trace_id",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Kafka Traces",
      "type": "table",
      "description": "Trace search uses the same service list as the Kafka completion logs.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "editorMode": "builder",
          "queryType": "traceql",
          "query": "{ resource.service.name =~ \"$service\" && span.messaging.system = \"kafka\" }",
          "limit": 50,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      }
    }
