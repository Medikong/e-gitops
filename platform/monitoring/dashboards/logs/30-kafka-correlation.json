              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "title": "Kafka Completion Logs",
      "type": "logs",
      "description": "No message key or payload is displayed.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service_name=~\"$service\"} | json | event=~\"kafka\\.message\\.(publish|process)\" | messaging_destination_name=~\"$topic\" | messaging_operation=~\"$operation\" | outcome=~\"$outcome\" | line_format \"event={{.event}} service={{.service_name}} topic={{.messaging_destination_name}} operation={{.messaging_operation}} outcome={{.outcome}} correlation_id={{.correlation_id}} trace_id={{.trace_id}} span_id={{.span_id}} failure_code={{.failure_code}}\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 6,
      "title": "Correlation ID Across Services",
      "type": "logs",
      "description": "Paste one correlation_id to follow producer and consumer logs.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"dropmong-.*\"} | json | correlation_id=~\"$correlation_id\" | line_format \"event={{.event}} service={{.service_name}} correlation_id={{.correlation_id}} trace_id={{.trace_id}} span_id={{.span_id}}\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 7,
      "title": "Trace / Span Focus",
      "type": "logs",
      "description": "Use span_id to select the producer or consumer operation within a trace.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
