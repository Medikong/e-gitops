  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Purpose",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "Follow asynchronous work across producer and consumer boundaries using the safe Kafka completion-log fields. The default service selector includes only broker-enabled active values: interest, order, payment and notification. The topic list comes from the DropMong data-plane bootstrap; message payloads are intentionally excluded."
      }
    },
    {
      "id": 2,
      "title": "Kafka Operations by Topic",
      "type": "timeseries",
      "description": "Producer and consumer completion logs by bounded topic and outcome.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name, messaging_destination_name, messaging_operation, outcome) (count_over_time({service_name=~\"$service\"} | json | event=~\"kafka\\.message\\.(publish|process)\" | messaging_destination_name=~\"$topic\" | messaging_operation=~\"$operation\" | outcome=~\"$outcome\" [$__interval]))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "Kafka Failures",
      "type": "stat",
      "description": "Failed publish or process operations.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 6,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({service_name=~\"$service\"} | json | event=~\"kafka\\.message\\.(publish|process)\" | messaging_destination_name=~\"$topic\" | messaging_operation=~\"$operation\" | outcome=\"failure\" [$__range]))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "title": "Failures Missing Trace ID",
      "type": "stat",
      "description": "A non-zero value indicates broken Kafka trace propagation.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 18,
        "y": 3,
        "w": 6,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({service_name=~\"$service\"} | json | event=~\"kafka\\.message\\.(publish|process)\" | messaging_destination_name=~\"$topic\" | outcome=\"failure\" | trace_id=\"\" [$__range]))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
