  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Purpose",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "Compare application failures by service and route. Collector exporter failures are a separate telemetry-pipeline signal and do not count as application 5xx."
      }
    },
    {
      "id": 2,
      "title": "5xx Logs by Service",
      "type": "timeseries",
      "description": "5xx access log volume by service.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | event=\"http.request.completed\" | http_route_kind=\"api\" | http_route=~\"$route\" | http_status_code=~\"5..\" [$__interval]))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "Structured Error Logs by Service",
      "type": "timeseries",
      "description": "All structured application error logs.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (count_over_time({k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | severity_text=~\"ERROR|CRITICAL\" [$__interval]))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Error Codes by Route",
      "type": "table",
      "description": "Bounded route templates and low-cardinality error codes.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "topk(30, sum by (service_name, http_route, http_status_code, http_error_code) (count_over_time({k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | http_route=~\"$route\" | http_status_code=~\"5..\" [$__range])))",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      }
    },
    {
      "id": 5,
      "title": "Application Error Detail",
      "type": "logs",
      "description": "Sensitive request or response bodies are not expected in this log contract.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | severity_text=~\"ERROR|CRITICAL\" | line_format \"event={{.event}} service={{.service_name}} error_code={{.http_error_code}} route={{.http_route}} request_id={{.request_id}} trace_id={{.trace_id}} span_id={{.span_id}}\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 6,
      "title": "Selected Request / Trace",
      "type": "logs",
      "description": "Paste exact identifiers from an error row to isolate retained logs.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\",service_name=~\"$service\"} | json | request_id=~\"$request_id\" | trace_id=~\"$trace_id\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 7,
      "title": "Collector Export Failure Detail",
      "type": "logs",
      "description": "Supplemental query only: Collector self-logs are excluded from the filelog pipeline, so an empty result does not prove export health. Use the Ops Collector self-metrics as the authoritative signal.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 18,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{k8s_namespace_name=\"observability\",k8s_container_name=\"opentelemetry-collector\"} |~ \"(?i)(exporting failed|failed to export|sending_queue is full)\"",
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
