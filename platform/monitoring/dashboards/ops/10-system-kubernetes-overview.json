    {
      "title": "Deployment Available Ratio",
      "type": "timeseries",
      "description": null,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (namespace, deployment) (kube_deployment_status_replicas_available{namespace=~\"${namespace:regex}\"}) / clamp_min(sum by (namespace, deployment) (kube_deployment_spec_replicas{namespace=~\"${namespace:regex}\"}), 1)",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [

      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
