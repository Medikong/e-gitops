  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Purpose",
      "type": "text",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "**Representative screen 1/4.** Start with request traffic, 5xx errors and latency, then check active requests, readiness and Kubernetes saturation. HTTP panels use only the DropMong application metric contract; no gateway or ingress metric is assumed."
      }
    },
    {
      "id": 2,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "description": "Completed API requests per second from the common HTTP duration histogram.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Open request investigation",
          "url": "/d/dropmong-logs-request-investigation/logs-10-request-investigation?orgId=1&var-environment=$environment&var-service=$service&var-route=$route&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "title": "5xx Error Ratio by Service",
      "type": "timeseries",
      "description": "5xx requests divided by all API requests. Empty data is not presented as SLO attainment.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (service_name) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\",http_response_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service_name) (rate(http_server_request_duration_seconds_count{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "Open request investigation",
          "url": "/d/dropmong-logs-request-investigation/logs-10-request-investigation?orgId=1&var-environment=$environment&var-service=$service&var-route=$route&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "title": "p95 / p99 Latency by Service",
      "type": "timeseries",
      "description": "Latency quantiles from the common application histogram.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(http_server_request_duration_seconds_bucket{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval])))",
          "legendFormat": "p95 {{service_name}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (service_name, le) (rate(http_server_request_duration_seconds_bucket{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"}[$__rate_interval])))",
          "legendFormat": "p99 {{service_name}}",
          "range": true,
          "refId": "B"
        }
      ],
      "links": [
        {
          "title": "Open request investigation",
          "url": "/d/dropmong-logs-request-investigation/logs-10-request-investigation?orgId=1&var-environment=$environment&var-service=$service&var-route=$route&from=${__from}&to=${__to}",
          "targetBlank": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "title": "Active Requests",
      "type": "timeseries",
      "description": "In-flight API requests. A sustained increase indicates saturation or a blocked dependency.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 10,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_name) (http_server_active_requests{service_environment=~\"$environment\",service_name=~\"$service\",http_route=~\"$route\",http_route_kind=\"api\"})",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "links": [],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
