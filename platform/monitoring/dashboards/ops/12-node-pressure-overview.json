    {
      "title": "Node Resource Snapshot",
      "type": "table",
      "description": "Current node CPU, memory and Pod occupancy. node_uname_info maps node-exporter instances to Kubernetes node names; Ready comes from kube-state-metrics.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (node) (kube_node_status_condition{condition=\"Ready\",status=\"true\"} == 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "Ready",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (node) (label_replace(sum by (instance) (rate(node_cpu_seconds_total{mode!=\"idle\"}[$__rate_interval])) * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\"))",
          "format": "table",
          "instant": true,
          "legendFormat": "CPU Used",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (node) (label_replace(count by (instance) (node_cpu_seconds_total{mode=\"idle\"}) * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\"))",
          "format": "table",
          "instant": true,
          "legendFormat": "CPU Total",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (node) (label_replace((1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval]))) * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\"))",
          "format": "table",
          "instant": true,
          "legendFormat": "CPU %",
          "range": false,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (node) (label_replace((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\"))",
          "format": "table",
          "instant": true,
          "legendFormat": "Memory Used",
          "range": false,
          "refId": "E"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (node) (label_replace(node_memory_MemTotal_bytes * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\"))",
          "format": "table",
          "instant": true,
          "legendFormat": "Memory Total",
          "range": false,
          "refId": "F"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (node) (label_replace((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\")) / clamp_min(sum by (node) (label_replace(node_memory_MemTotal_bytes * on (instance) group_left (nodename) node_uname_info, \"node\", \"$1\", \"nodename\", \"(.+)\")), 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "Memory %",
          "range": false,
          "refId": "G"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (node) ((kube_pod_status_phase{phase=\"Running\"} == 1) * on (namespace, pod) group_left (node) kube_pod_info)",
          "format": "table",
          "instant": true,
          "legendFormat": "Running Pods",
          "range": false,
          "refId": "H"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (node) ((kube_pod_status_phase{phase=\"Running\"} == 1) * on (namespace, pod) group_left (node) kube_pod_info) / clamp_min(max by (node) (kube_node_status_capacity{resource=\"pods\",unit=\"integer\"}), 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "Pod %",
          "range": false,
          "refId": "I"
        }
      ],
      "links": [

