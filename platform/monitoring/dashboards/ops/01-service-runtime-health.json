    {
      "title": "Service Status Grid",
      "type": "table",
      "description": "One row per DropMong namespace. Unhealthy availability, unready Pods, restarts and OOMKilled evidence are color-coded; the selected dashboard time range controls restart and OOM history.",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace) (kube_deployment_spec_replicas{namespace=~\"${namespace:regex}\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "Desired",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace) (kube_deployment_status_replicas_available{namespace=~\"${namespace:regex}\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "Available",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace) (kube_deployment_status_replicas_unavailable{namespace=~\"${namespace:regex}\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "Unavailable",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum by (namespace) (kube_deployment_status_replicas_available{namespace=~\"${namespace:regex}\"}) / clamp_min(sum by (namespace) (kube_deployment_spec_replicas{namespace=~\"${namespace:regex}\"}), 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "Available %",
          "range": false,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace) (kube_pod_status_ready{namespace=~\"${namespace:regex}\",condition=\"false\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "Ready False",
          "range": false,
          "refId": "E"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "round(sum by (namespace) (increase(kube_pod_container_status_restarts_total{namespace=~\"${namespace:regex}\",container!=\"\",container!=\"POD\"}[$__range])))",
          "format": "table",
          "instant": true,
          "legendFormat": "Restarts",
          "range": false,
          "refId": "F"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "(sum by (namespace) (max_over_time(kube_pod_container_status_last_terminated_reason{namespace=~\"${namespace:regex}\",reason=\"OOMKilled\",container!=\"\"}[$__range])) or on (namespace) 0 * sum by (namespace) (kube_pod_info{namespace=~\"${namespace:regex}\"}))",
          "format": "table",
          "instant": true,
          "legendFormat": "OOMKilled",
          "range": false,
          "refId": "G"
        }
