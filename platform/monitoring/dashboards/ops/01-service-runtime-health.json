            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sort_desc(100 * sum by (namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"${namespace:regex}\",container!=\"\",container!=\"POD\",image!=\"\"}[$__rate_interval])) / clamp_min(sum by (namespace) (kube_pod_container_resource_limits{namespace=~\"${namespace:regex}\",resource=\"cpu\",unit=\"core\",container!=\"\",container!=\"POD\"}), 0.001))",
